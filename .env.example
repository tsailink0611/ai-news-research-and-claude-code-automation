# AI News Research - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# 必須API（コア機能）
# ============================================

# Grok API (xAI) - X上のAIニュースをリアルタイム取得
# https://console.x.ai/ でAPIキーを取得
GROK_API_KEY=your_grok_api_key_here
GROK_API_BASE=https://api.x.ai/v1

# Anthropic Claude API - 高品質な要約・ドラフト生成
# https://console.anthropic.com/ でAPIキーを取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================
# オプションAPI（各ソース強化）
# ============================================

# Hacker News API (APIキー不要、公開API)
HN_API_BASE=https://hacker-news.firebaseio.com/v0

# YouTube Data API v3 - 海外AI動画リサーチ
# https://console.cloud.google.com/ で取得（無料枠 10,000ユニット/日）
YOUTUBE_API_KEY=your_youtube_api_key_here

# Reddit (公開JSON APIはキー不要、OAuth使用時のみ必要)
# REDDIT_CLIENT_ID=your_client_id_here
# REDDIT_CLIENT_SECRET=your_client_secret_here

# Product Hunt API
# https://www.producthunt.com/v2/oauth/applications で取得
PRODUCTHUNT_ACCESS_TOKEN=your_producthunt_token_here

# SerpApi - Google検索結果・サジェスト分析
# https://serpapi.com/ で取得（無料枠 月250回）
SERPAPI_KEY=your_serpapi_key_here

# X/Twitter API v2 - ブックマーク取得
# https://developer.twitter.com/ で取得
X_BEARER_TOKEN=your_x_bearer_token_here

# Google Trends (APIキー不要、pytrends使用)

# 中国SNS (APIキー不要、公開API使用)

# ============================================
# Telegram通知（プッシュ型配信）
# ============================================

# Telegram Bot Token - @BotFather でBot作成して取得
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID - @userinfobot に /start して自分のIDを確認
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# 出力設定
# ============================================
MAX_X_DRAFTS=30
DEFAULT_LANGUAGE=ja
